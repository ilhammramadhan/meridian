# Path to the Meridian agent project (defaults to the parent dir of this dashboard)
MERIDIAN_DIR=..
# Optional: override the brain wiki dir (defaults to $MERIDIAN_DIR/brain)
# MERIDIAN_BRAIN_DIR=../brain
# Optional: pin the node binary used to run cli.js (nvm path, etc.)
# MERIDIAN_NODE=node

# Safety: keep dry-run during integration; flip to false for live trading from the dashboard
DRY_RUN=true

# Claude session used to stream screen/manage cycle reasoning (no API key — uses `claude login`)
CLAUDE_MODEL=opus
# CLAUDE_BIN=/Users/you/.local/bin/claude
# CLAUDE_PERMISSION_MODE=default
# CLAUDE_CYCLE_TIMEOUT_MS=600000
